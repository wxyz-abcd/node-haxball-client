{
  "name": "node-haxball-client",
  "main": "main.js",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && nw . --user-data-dir=.nw-local-data development\"",
    "preview": "cross-env vite build && cross-env nw ./ production",
    "dist:win": "vite build && nwbuild --platform=win --mode=build --flavor=sdk --cacheDir=../nw-cache --outDir=../node-haxball-client-out/win --managedManifest=true \"./dist/**/* ./main.js ./package.json\"",
    "dist:linux": "vite build && nwbuild --platform=linux --mode=build --flavor=sdk --cacheDir=../nw-cache --outDir=../node-haxball-client-out/linux --managedManifest=true \"./dist/**/* ./main.js ./package.json\"",
    "dist:all": "npm run dist:win && npm run dist:linux",
    "zip:win": "npm run dist:win && powershell -Command \"Compress-Archive -Path '../node-haxball-client-out/win/*' -DestinationPath '../node-haxball-client-out/node-haxball-client-win.zip' -Force\"",
    "zip:linux": "npm run dist:linux && powershell -Command \"Compress-Archive -Path '../node-haxball-client-out/linux/*' -DestinationPath '../node-haxball-client-out/node-haxball-client-linux.zip' -Force\"",
    "lint": "eslint ."
  },
  "window": {
    "icon": "",
    "transparent": true,
    "frame": true
  },
  "chromium-args": "--allow-file-access-from-files --disable-web-security --disable-frame-rate-limit --disable-gpu-vsync --force-gpu-rasterization --ignore-gpu-blocklist --enable-zero-copy",
  "node-remote": "<all_urls>",
  "dependencies": {
    "@koush/wrtc": "^0.5.3",
    "node-haxball": "^2.2.0",
    "perfect-scrollbar": "^1.5.6",
    "re-resizable": "^6.11.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.8.1",
    "win32-api": "^26.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "nw": "0.110.1-sdk",
    "nw-builder": "^4.15.0",
    "vite": "^7.0.4",
    "wait-on": "^9.0.4"
  }
}

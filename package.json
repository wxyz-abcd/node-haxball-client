{
  "name": "node-haxball-client",
  "main": "main.js",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"cross-env vite\" \"cross-env nw ./ development\"",
    "preview": "cross-env vite build && cross-env nw ./ production",
    "dist": "vite build && nwbuild --platform=linux --mode=build --glob=false --flavor=sdk --cacheDir=./node_modules/nw ./",
    "lint": "eslint ."
  },
  "window": {
    "transparent": true,
    "frame": true
  },
  "chromium-args": "--allow-file-access-from-files --disable-web-security",
  "node-remote": "<all_urls>",
  "dependencies": {
    "@koush/wrtc": "^0.5.3",
    "node-haxball": "^2.2.0",
    "perfect-scrollbar": "^1.5.6",
    "re-resizable": "^6.11.2",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-router-dom": "7.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "nw": "0.103.0-sdk",
    "nw-builder": "^4.15.0",
    "vite": "7.2.7"
  }
}
